<div class="top-bar">
  <span class="title">Novo Livro</span>
  <%= link_to "Voltar", dashboard_path, class: "back-button" %>
</div>

<div class="container-new-book">
  <div class="new-book-card">
    <% if @book.errors.any? %>
      <div class="errors-messages">
        <h3><%= pluralize(@book.errors.count, "erro") %> impediram o salvamento:</h3>
        <ul>
          <% @book.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with(model: @book, local: true) do |form| %>
      <div class="form-group">
        <%= form.label :title, "Título" %>
        <%= form.text_field :title %>
      </div>

      <div class="form-group">
        <%= form.label :author, "Autor" %>
        <%= form.text_field :author %>
      </div>

      <div class="form-group">
        <%= form.label :price, "Preço" %>
        <%= form.number_field :price, step: 0.01 %>
      </div>

      <div class="form-actions">
        <%= form.submit "Criar Livro", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
