<h1>Novo Livro</h1>

<%= form_with(model: @book, local: true) do |form| %>
  <div class="form-group">
    <%= form.label :title, "Título" %><br>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :author, "Autor" %><br>
    <%= form.text_field :author, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :price, "Preço" %><br>
    <%= form.number_field :price, step: 0.01, class: "form-control" %>
  </div>

  <div class="form-actions" style="margin-top: 15px;">
    <%= form.submit "Criar Livro", class: "btn btn-primary" %>
    <%= link_to "Voltar", dashboard_path, class: "btn btn-secondary" %>
  </div>
<% end %>
