<!-- Barra superior -->
<div class="top-bar">
  <span>Meus Livros</span>
  <%= link_to 'Voltar', dashboard_path, class: 'btn-back' %>
</div>


<% if @books.any? %>
  <table class="books-table">
    <thead>
      <tr>
        <th>Título</th>
        <th>Autor</th>
        <th>Preço</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td><%= book.title %></td>
          <td><%= book.author %></td>
          <td><%= number_to_currency(book.price) %></td>
          <td>
  <div class="btn-group">
    <%= link_to 'Editar', edit_book_path(book), class: 'btn-action' %>
    <%= button_to 'Deletar', book_path(book), method: :delete, data: { confirm: 'Tem certeza?' }, class: 'btn-action delete' %>
  </div>
</td>

        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Nenhum livro cadastrado.</p>
<% end %>
