<div class="top-bar">
  <span class="title">Meus Livros</span>
  <%= link_to "Voltar", dashboard_path, class: "back-button" %>
</div>

<% if @books.any? %>
  <table border="1" cellpadding="5" cellspacing="0">
    <thead>
      <tr>
        <th>Título</th>
        <th>Autor</th>
        <th>Preço</th>
        <th>Prazo</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td><%= book.title %></td>
          <td><%= book.author %></td>
          <td><%= number_to_currency(book.price, unit: "R$", separator: ",", delimiter: ".") %></td>
          <td>
            <%= form_with url: rent_book_path(book), method: :post, local: true do |f| %>
              <%= f.date_field :end_date, value: Date.today + 7.days %>
          </td>
          <td>
              <%= f.submit "Alugar" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Não há livros cadastrados no momento.</p>
<% end %>
