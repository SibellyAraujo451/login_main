<h1>Alugar Livro: <%= @book.title %></h1>

<%= form_with url: rent_book_path(@book), method: :post, local: true do |f| %>
  <div>
    <%= f.label :end_date, "Escolha a data de devolução:" %>
    <%= f.date_field :end_date, value: Date.today + 7.days %>
  </div>

  <div>
    <%= f.submit "Alugar" %>
  </div>
<% end %>

<p><%= link_to "Voltar", books_path %></p>
