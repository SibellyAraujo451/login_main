<div class="top-bar">
  <span class="title">Editar Perfil</span>
  <%= link_to "Voltar", dashboard_path, class: "back-button" %>
</div>

<div class="container-edit-user">
  <div class="edit-card">
    <%# Formulário de edição %>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

      <% if resource.errors.any? %>
        <div class="errors-messages">
          <h3><%= pluralize(resource.errors.count, "erro") %> proibiu este usuário de ser salvo:</h3>
          <ul>
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Campo Email -->
      <div class="field">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <!-- Campo Password -->
      <div class="field">
        <%= f.label :password %> <i>(deixe em branco caso não queira alterar)</i>
        <%= f.password_field :password, autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <br><em><%= @minimum_password_length %> caracteres mínimo</em>
        <% end %>
      </div>

      <!-- Campo Password Confirmation -->
      <div class="field">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <!-- Campo Current Password -->
      <div class="field">
        <%= f.label :current_password, "Senha Atual" %> <i>(necessário para confirmar alterações)</i>
        <%= f.password_field :current_password, autocomplete: "current-password" %>
      </div>

      <div class="actions">
        <%= f.submit "Atualizar Perfil" %>
      </div>

    <% end %>
  </div>
</div>
